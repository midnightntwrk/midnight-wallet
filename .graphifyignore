# .graphifyignore — extends .gitignore for graphify scans (gitignore syntax).
# node_modules/, dist/, build artifacts etc. are already excluded twice over:
# graphify respects .gitignore and has them hardcoded as skip dirs.

# CI/repo plumbing — no graph value
.github/
.claude/

