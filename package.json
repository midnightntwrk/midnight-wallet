{
  "packageManager": "yarn@4.17.0",
  "name": "@midnightntwrk/wallet-sdk-monorepo",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@effect/language-service": "0.86.6",
    "@eslint/compat": "2.1.0",
    "@eslint/js": "10.0.1",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/runner": "4.1.10",
    "@vitest/ui": "4.1.10",
    "dotenv": "17.4.2",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "fast-check": "4.9.0",
    "prettier": "3.9.5",
    "prettier-plugin-jsdoc": "1.8.1",
    "publint": "0.3.21",
    "rimraf": "6.1.3",
    "testcontainers": "11.14.0",
    "tslib": "2.8.1",
    "turbo": "2.10.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  },
  "resolutions": {
    "vitest": "4.1.10",
    "vite": "^7.3.1",
    "readdir-glob": "^3.0.0",
    "minimatch": "^10.2.3",
    "tar": "^7.5.5",
    "lodash": "^4.17.23",
    "protobufjs": "^8.0.0",
    "flatted": "^3.4.2",
    "immutable": "^5.0.0",
    "picomatch@npm:^2.3.1": "^2.3.2",
    "picomatch@npm:^4.0.2": "^4.0.4",
    "picomatch@npm:^4.0.3": "^4.0.4",
    "rollup": "^4.60.2",
    "undici": "8.7.0",
    "bn.js@npm:^4.0.0": "^4.12.3",
    "bn.js@npm:^4.1.0": "^4.12.3",
    "bn.js@npm:^4.11.9": "^4.12.3",
    "qs": "^6.15.1",
    "uuid": "^14.0.0",
    "yaml": "^2.8.3",
    "glob@npm:^10.0.0": "^13.0.6",
    "@substrate/connect": "^2.0.0",
    "shell-quote": "^1.8.4",
    "@grpc/grpc-js": "^1.14.4",
    "postcss": "^8.5.10",
    "brace-expansion": "^5.0.6",
    "@babel/core": "^7.29.6",
    "js-yaml@npm:^4.1.0": "^4.2.0",
    "js-yaml@npm:^4.1.1": "^4.2.0",
    "ip-address@npm:^10.0.1": "^10.1.1"
  },
  "scripts": {
    "format:root": "prettier --write --ignore-path .prettierignore.root \"**/*.{ts,js,json,yaml,yml,md}\"",
    "format:check:root": "prettier --check --ignore-path .prettierignore.root \"**/*.{ts,js,json,yaml,yml,md}\"",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "verify": "turbo run verify",
    "verify:check": "turbo run verify:check",
    "verify:test": "turbo run verify:test",
    "verify:integration": "turbo run verify:integration",
    "publint": "turbo run publint",
    "check-barrel-exports": "node scripts/check-barrel-exports.mjs",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "dist": "turbo run dist",
    "schema:sync": "turbo run schema:sync",
    "watch": "turbo watch dist",
    "dist:publish": "turbo run dist:publish",
    "changeset:version": "yarn changeset version && yarn install --mode=update-lockfile",
    "changeset:check": "yarn changeset status --verbose",
    "clean": "turbo run clean"
  }
}
