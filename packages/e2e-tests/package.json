{
  "name": "@midnight/wallet-e2e-tests",
  "version": "0.0.1",
  "description": "Typescript wallet tests",
  "author": "Midnight Foundation",
  "private": true,
  "type": "module",
  "scripts": {
    "test-e2e": "NODE_OPTIONS='--experimental-vm-modules --experimental-specifier-resolution=node --max-old-space-size=16384 --heapsnapshot-near-heap-limit=1' vitest run",
    "test-undeployed": "docker compose -f ../../infra/compose/docker-compose-dynamic.yml pull && yarn test-e2e --project undeployed",
    "test-remote": "docker compose -f ../../infra/compose/docker-compose-remote-dynamic.yml pull && yarn test-e2e --project remote",
    "typecheck": "tsc -b ./tsconfig.json --noEmit --force",
    "format": "prettier --write \"**/*.{ts,js,json,yaml,yml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,yaml,yml,md}\"",
    "lint": "eslint --max-warnings 0"
  },
  "devDependencies": {
    "@cardano-sdk/key-management": "0.29.15",
    "@midnight-ntwrk/ledger-v8": "^8.1.0",
    "@midnightntwrk/wallet-sdk-abstractions": "workspace:*",
    "@midnightntwrk/wallet-sdk-address-format": "workspace:*",
    "@midnightntwrk/wallet-sdk-capabilities": "workspace:^",
    "@midnightntwrk/wallet-sdk-dust-wallet": "workspace:^",
    "@midnightntwrk/wallet-sdk-facade": "workspace:^",
    "@midnightntwrk/wallet-sdk-hd": "workspace:^",
    "@midnightntwrk/wallet-sdk-runtime": "workspace:^",
    "@midnightntwrk/wallet-sdk-shielded": "workspace:^",
    "@midnightntwrk/wallet-sdk-testkit": "workspace:^",
    "@midnightntwrk/wallet-sdk-unshielded-wallet": "workspace:^",
    "@midnightntwrk/wallet-sdk-utilities": "workspace:^",
    "@types/node": "24.13.2",
    "@vitest/ui": "4.1.9",
    "eslint": "10.6.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prettier": "3.9.4",
    "rxjs": "7.8.2",
    "testcontainers": "11.14.0",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
