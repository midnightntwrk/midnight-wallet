{
  "name": "@midnight/wallet-e2e-tests",
  "version": "0.0.1",
  "description": "Typescript wallet tests",
  "author": "Midnight Foundation",
  "private": true,
  "type": "module",
  "scripts": {
    "test-e2e": "NODE_OPTIONS='--experimental-vm-modules --experimental-specifier-resolution=node --max-old-space-size=16384 --heapsnapshot-near-heap-limit=1' vitest run",
    "test-undeployed": "docker compose -f ../../infra/compose/docker-compose-dynamic.yml pull && yarn test-e2e --project undeployed",
    "test-remote": "docker compose -f ../../infra/compose/docker-compose-remote-dynamic.yml pull && yarn test-e2e --project remote",
    "typecheck": "tsc -b ./tsconfig.json --noEmit --force",
    "format": "prettier --write \"**/*.{ts,js,json,yaml,yml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,yaml,yml,md}\"",
    "lint": "eslint --max-warnings 0"
  },
  "devDependencies": {
    "@cardano-sdk/key-management": "0.29.13",
    "@midnight-ntwrk/ledger-v9": "0.1.0-alpha.1",
    "@midnight-ntwrk/midnight-js-network-id": "^3.1.0",
    "@midnight-ntwrk/wallet-sdk-abstractions": "workspace:*",
    "@midnight-ntwrk/wallet-sdk-address-format": "workspace:*",
    "@midnight-ntwrk/wallet-sdk-facade": "workspace:^",
    "@midnight-ntwrk/wallet-sdk-hd": "workspace:^",
    "@midnight-ntwrk/wallet-sdk-shielded": "workspace:^",
    "@midnight-ntwrk/wallet-sdk-testkit": "workspace:^",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "workspace:^",
    "@midnight-ntwrk/wallet_qanet": "npm:@midnight-ntwrk/wallet@3.7.4",
    "@types/node": "25.9.3",
    "@types/ws": "8.18.1",
    "@vitest/runner": "4.1.8",
    "@vitest/ui": "4.1.8",
    "eslint": "10.4.1",
    "fp-ts": "2.16.11",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "rxjs": "7.8.2",
    "shx": "0.4.0",
    "testcontainers": "11.14.0",
    "tsc-watch": "7.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8",
    "vitest-ctrf-json-reporter": "0.0.3",
    "ws": "8.21.0"
  }
}
