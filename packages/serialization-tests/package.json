{
  "name": "@midnight/wallet-serialization-tests",
  "description": "Cross-version serialization compatibility tests: restore fixtures produced by previously published SDK versions with the current workspace code",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "author": "Midnight Foundation",
  "license": "Apache-2.0",
  "scripts": {
    "typecheck": "tsc -b ./tsconfig.json --noEmit --force",
    "test": "vitest run",
    "test:unit": "vitest run --project unit --passWithNoTests",
    "test:serialization:compat": "vitest run --project unit --passWithNoTests Compat",
    "test:serialization:drift": "vitest run --project unit --passWithNoTests Drift",
    "test:integration": "vitest run --project integration --passWithNoTests",
    "lint": "eslint --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,js,json,yaml,yml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,yaml,yml,md}\""
  },
  "devDependencies": {
    "@midnight-ntwrk/ledger-v8": "^8.1.0",
    "@midnightntwrk/wallet-sdk-abstractions": "workspace:*",
    "@midnightntwrk/wallet-sdk-capabilities": "workspace:^",
    "@midnightntwrk/wallet-sdk-dust-wallet": "workspace:^",
    "@midnightntwrk/wallet-sdk-facade": "workspace:^",
    "@midnightntwrk/wallet-sdk-shielded": "workspace:^",
    "@midnightntwrk/wallet-sdk-unshielded-wallet": "workspace:^",
    "@types/node": "24.13.2",
    "effect": "^3.19.19",
    "eslint": "10.6.0",
    "prettier": "3.8.4",
    "rxjs": "7.8.2",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
