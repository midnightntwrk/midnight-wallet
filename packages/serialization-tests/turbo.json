{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "test": {
      "inputs": [
        "test/**/*.{ts,tsx}",
        "fixtures/**/*.json",
        "tsconfig*.json",
        "$TURBO_ROOT$/tsconfig.base.json",
        "vitest.config.ts"
      ]
    },
    "test:unit": {
      "inputs": [
        "test/**/*.{ts,tsx}",
        "fixtures/**/*.json",
        "tsconfig*.json",
        "$TURBO_ROOT$/tsconfig.base.json",
        "vitest.config.ts"
      ]
    }
  }
}
