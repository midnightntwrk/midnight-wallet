{
  "name": "@midnightntwrk/wallet-sdk-testkit",
  "description": "Reusable wallet-SDK test harness: environment provisioning, wallet bootstrapping, sync waiters and tx-history assertions",
  "version": "0.2.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Midnight Foundation",
  "license": "Apache-2.0",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/midnightntwrk/midnight-wallet.git",
    "directory": "packages/wallet-sdk-testkit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./testcontainers": {
      "types": "./dist/testcontainers.d.ts",
      "import": "./dist/testcontainers.js"
    },
    "./scenarios": {
      "types": "./dist/scenarios/index.d.ts",
      "import": "./dist/scenarios/index.js"
    }
  },
  "dependencies": {
    "@midnight-ntwrk/ledger-v8": "^8.1.0",
    "@midnightntwrk/wallet-sdk-abstractions": "3.0.0",
    "@midnightntwrk/wallet-sdk-address-format": "3.1.2",
    "@midnightntwrk/wallet-sdk-capabilities": "3.4.0",
    "@midnightntwrk/wallet-sdk-dust-wallet": "5.0.0",
    "@midnightntwrk/wallet-sdk-facade": "5.0.0",
    "@midnightntwrk/wallet-sdk-hd": "3.0.3",
    "@midnightntwrk/wallet-sdk-indexer-client": "1.3.0",
    "@midnightntwrk/wallet-sdk-shielded": "3.1.0",
    "@midnightntwrk/wallet-sdk-unshielded-wallet": "3.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rxjs": "^7.8.2"
  },
  "peerDependencies": {
    "@midnightntwrk/wallet-sdk-utilities": "1.2.0",
    "testcontainers": "^11.12.0",
    "vitest": "^4.1.4"
  },
  "peerDependenciesMeta": {
    "@midnightntwrk/wallet-sdk-utilities": {
      "optional": true
    },
    "testcontainers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@midnightntwrk/wallet-sdk-utilities": "workspace:^",
    "rimraf": "6.1.3",
    "testcontainers": "11.14.0",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  },
  "scripts": {
    "typecheck": "tsc -b ./tsconfig.json --noEmit --force",
    "lint": "eslint --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,js,json,yaml,yml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,yaml,yml,md}\"",
    "dist": "tsc -b ./tsconfig.build.json",
    "dist:publish": "tsc -b ./tsconfig.publish.json",
    "clean": "rimraf --glob dist 'tsconfig.*.tsbuildinfo'",
    "publint": "publint --strict"
  }
}
